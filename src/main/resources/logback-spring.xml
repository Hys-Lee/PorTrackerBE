<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 로그 패턴 정의: [시간] [레벨] [스레드명] [클래스명] : 메시지 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) : %msg%n"/>

    <!-- 1. 콘솔 출력 (개발용) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 2. Sentry 전송 (운영/장애 분석용) -->
    <!-- 로그 레벨이 WARN 이상인 에러/경고성 로그를 실시간 Sentry 클라우드로 전송합니다. -->
    <appender name="SENTRY" class="io.sentry.logback.SentryAppender">
        <options>
            <minimumEventLevel>WARN</minimumEventLevel>
            <minimumBreadcrumbLevel>INFO</minimumBreadcrumbLevel>
        </options>
    </appender>

    <!-- 프로젝트 전체 로그 레벨 설정 -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="SENTRY" />
    </root>
</configuration>